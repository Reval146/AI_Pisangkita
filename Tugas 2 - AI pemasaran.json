    },
    {
      "parameters": {
        "jsCode": "const result = JSON.parse($json.data?.resultJson || \"{}\");\n\nreturn [{\n  img1: result.resultUrls?.[0] || null,\n  img2: result.resultUrls?.[1] || null,\n  img3: result.resultUrls?.[2] || null,\n  img4: result.resultUrls?.[3] || null\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "id": "b2fdc199-5db9-4f14-a352-d1377d176909",
      "name": "Format Result"
    },
    {
      "parameters": {
        "jsCode": "const urls = [\n  $json.img1,\n  $json.img2,\n  $json.img3,\n  $json.img4\n].filter(Boolean);\n\n// jadikan 1 URL = 1 item\nreturn urls.map((url, index) => ({\n  json: {\n    url,\n    index: index + 1\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
